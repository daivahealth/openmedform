# Database
POSTGRES_USER=openmedform
POSTGRES_PASSWORD=changeme
POSTGRES_DB=openmedform
DATABASE_URL=postgresql://openmedform:changeme@localhost:5432/openmedform?schema=public

# Auth
JWT_SECRET=changeme-to-a-secure-random-string
JWT_EXPIRY=24h

# App
PORT=3100
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3100

# Docker Compose (production)
# HTTP_PORT=80

# AI Provider Encryption (required for DB-stored API keys)
# Must be at least 32 characters. Generate with: openssl rand -hex 32
# AI_ENCRYPTION_KEY=your-random-key-at-least-32-chars-long

# AI Builder — configure one or more providers (env var fallback, optional if using Settings UI)
# AI_DEFAULT_PROVIDER=claude

# Anthropic Claude
# AI_CLAUDE_API_KEY=sk-ant-...
# AI_CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI
# AI_OPENAI_API_KEY=sk-...
# AI_OPENAI_MODEL=gpt-4o

# MiniMax
# AI_MINIMAX_API_KEY=...
# AI_MINIMAX_MODEL=abab6.5-chat

# Kimi (Moonshot)
# AI_KIMI_API_KEY=...
# AI_KIMI_MODEL=moonshot-v1-8k

# Ollama (local)
# AI_OLLAMA_BASE_URL=http://localhost:11434
# AI_OLLAMA_MODEL=llama3
